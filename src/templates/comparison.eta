<% const c = it.page.comparison; const entry = it.entry; %>

<!-- ========== HERO ========== -->
<section class="bg-cream grain-bg pt-32 pb-16 lg:pt-40 lg:pb-24 relative overflow-hidden">
  <div class="absolute w-[500px] h-[500px] bg-yellowSoft rounded-full blur-[120px] opacity-15 -top-20 -right-20"></div>
  <div class="absolute w-[400px] h-[400px] bg-sage rounded-full blur-[100px] opacity-10 bottom-0 -left-10"></div>

  <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
    <div class="inline-flex items-center gap-2 bg-sage/10 text-sage rounded-full px-4 py-2 text-sm font-medium mb-6">
      <span class="material-symbols-outlined text-lg">compare</span>
      <span><%= c.eyebrow %></span>
    </div>
    <h1 class="text-4xl lg:text-[56px] font-extrabold text-darkBlue leading-tight mb-6"><%= c.h1 %></h1>
    <p class="text-lg lg:text-xl text-gray-500 max-w-2xl mx-auto mb-10"><%= c.intro %></p>

    <div class="flex flex-row items-center justify-center gap-3 sm:gap-4 flex-wrap">
      <a href="<%= it.appStoreUrl %>" target="_blank" rel="noopener" class="hover:opacity-80 transition-opacity">
        <img src="/assets/badges/preorder-<%= it.locale %>.svg" alt="Pre-order on the App Store" style="height:48px;width:auto;">
      </a>
      <a href="#cta" class="hero-promo-cta inline-flex items-center justify-center gap-2 text-terracotta font-semibold border-2 border-terracotta rounded-xl hover:bg-terracotta/5 transition-colors" style="height:48px;padding:0 24px;">
        <span class="material-symbols-outlined text-xl">star</span>
        <span><%= c.cta_promo %></span>
      </a>
    </div>
  </div>
</section>

<!-- ========== COMPARISON TABLE ========== -->
<section class="bg-white py-20 lg:py-28">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl lg:text-5xl font-extrabold text-darkBlue text-center mb-4 reveal"><%= c.table_title %></h2>
    <p class="text-lg text-gray-500 text-center mb-12 reveal"><%= c.table_subtitle %></p>

    <div class="overflow-x-auto reveal">
      <table class="w-full border-collapse min-w-[600px]">
        <thead>
          <tr>
            <th class="text-left p-4 text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= c.table_header_feature %></th>
            <th class="text-center p-4 bg-terracotta/5 rounded-tl-2xl rounded-tr-2xl">
              <div class="flex items-center justify-center gap-2">
                <img src="/assets/favicon-40.png" alt="HomePot" class="w-7 h-7 rounded-lg">
                <span class="text-lg font-extrabold text-darkBlue">HomePot</span>
              </div>
            </th>
            <th class="text-center p-4 text-lg font-bold text-gray-500"><%= entry.competitor %></th>
          </tr>
        </thead>
        <tbody>
          <% c.features.forEach((row, idx) => {
            const isLast = idx === c.features.length - 1;
          %>
          <tr class="border-t border-gray-100">
            <td class="p-4 text-sm font-medium text-darkBlue"><%= row.label %></td>
            <td class="p-4 text-center bg-terracotta/5 <%= isLast ? 'rounded-bl-2xl rounded-br-2xl' : '' %>">
              <% if (row.ours === true) { %>
                <span class="material-symbols-outlined text-sage text-2xl">check_circle</span>
              <% } else if (row.ours === false) { %>
                <span class="material-symbols-outlined text-gray-300 text-2xl">cancel</span>
              <% } else { %>
                <span class="text-sm font-semibold text-darkBlue"><%= row.ours %></span>
              <% } %>
            </td>
            <td class="p-4 text-center">
              <% if (row.theirs === true) { %>
                <span class="material-symbols-outlined text-sage text-2xl">check_circle</span>
              <% } else if (row.theirs === false) { %>
                <span class="material-symbols-outlined text-gray-300 text-2xl">cancel</span>
              <% } else { %>
                <span class="text-sm text-gray-500"><%= row.theirs %></span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <p class="text-xs text-gray-400 text-center mt-6"><%= c.table_disclaimer %></p>
  </div>
</section>

<!-- ========== DIFFERENTIATORS ========== -->
<section class="bg-cream grain-bg py-20 lg:py-28">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl lg:text-5xl font-extrabold text-darkBlue text-center mb-4 reveal"><%= c.diff_title %></h2>
    <p class="text-lg text-gray-500 text-center mb-16 reveal"><%= c.diff_subtitle %></p>

    <div class="grid md:grid-cols-2 gap-6">
      <% c.differentiators.forEach((d, idx) => { %>
      <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm reveal reveal-delay-<%= (idx % 3) + 1 %>">
        <div class="w-12 h-12 bg-terracotta/10 rounded-xl flex items-center justify-center mb-5">
          <span class="material-symbols-outlined text-terracotta text-2xl"><%= d.icon %></span>
        </div>
        <h3 class="text-xl font-extrabold text-darkBlue mb-3"><%= d.title %></h3>
        <p class="text-gray-500 leading-relaxed"><%= d.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ========== HONEST NOTE (when competitor is excellent too) ========== -->
<% if (c.honest_note) { %>
<section class="bg-white py-16">
  <div class="max-w-3xl mx-auto px-6">
    <div class="bg-yellowSoft/20 border border-yellowSoft/40 rounded-3xl p-8 lg:p-10 reveal">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-12 h-12 bg-yellowSoft/40 rounded-xl flex items-center justify-center">
          <span class="material-symbols-outlined text-darkBlue text-2xl">handshake</span>
        </div>
        <div class="flex-1">
          <div class="text-xs font-semibold text-darkBlue/60 uppercase tracking-wider mb-2"><%= c.honest_note.eyebrow %></div>
          <h3 class="text-2xl font-extrabold text-darkBlue mb-3"><%= c.honest_note.title %></h3>
          <p class="text-gray-600 leading-relaxed"><%= c.honest_note.body %></p>
        </div>
      </div>
    </div>
  </div>
</section>
<% } %>

<!-- ========== REAL APP STORE REVIEWS ========== -->
<% if (c.reviews && c.reviews.length) { %>
<section class="bg-white py-20 lg:py-28">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-3xl lg:text-5xl font-extrabold text-darkBlue text-center mb-4 reveal"><%= c.reviews_title %></h2>
    <p class="text-lg text-gray-500 text-center mb-4 reveal"><%= c.reviews_subtitle %></p>
    <% if (c.reviews_meta) { %>
    <p class="text-sm text-gray-400 text-center mb-16 reveal"><%= c.reviews_meta %></p>
    <% } %>

    <div class="space-y-5">
      <% c.reviews.forEach(r => { %>
      <figure class="bg-cream/60 rounded-2xl p-6 border-l-4 border-terracotta reveal">
        <div class="flex items-center gap-2 mb-3 text-terracotta">
          <% for (let i = 0; i < (r.rating || 1); i++) { %><span class="material-symbols-outlined text-base">star</span><% } %>
          <% for (let i = (r.rating || 1); i < 5; i++) { %><span class="material-symbols-outlined text-base text-gray-300">star</span><% } %>
        </div>
        <blockquote class="text-darkBlue leading-relaxed mb-3">"<%= r.quote %>"</blockquote>
        <figcaption class="text-sm text-gray-500">— <%= r.author %><% if (r.date) { %> · <%= r.date %><% } %></figcaption>
      </figure>
      <% }) %>
    </div>

    <p class="text-xs text-gray-400 text-center mt-8"><%= c.reviews_disclaimer %></p>
  </div>
</section>
<% } %>

<!-- ========== FAQ ========== -->
<section class="bg-cream grain-bg py-20 lg:py-28">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-3xl lg:text-4xl font-extrabold text-darkBlue text-center mb-12 reveal"><%= c.faq_title %></h2>
    <div class="space-y-3 reveal">
      <% c.faq.forEach(item => { %>
      <details class="group bg-white rounded-2xl border border-gray-100 overflow-hidden">
        <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-darkBlue list-none">
          <span><%= item.q %></span>
          <span class="material-symbols-outlined text-gray-400 group-open:rotate-180 transition-transform">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-gray-500 text-sm leading-relaxed"><%= item.a %></div>
      </details>
      <% }) %>
    </div>
  </div>
</section>

<%~ include('partials/cta-final', it) %>
