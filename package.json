{
  "name": "homepotapp-web",
  "version": "1.0.0",
  "private": true,
  "description": "HomePot marketing site — static multilingual generator",
  "type": "module",
  "scripts": {
    "build": "node build.js && pnpm run build:css",
    "build:css": "tailwindcss -i src/styles/tailwind.css -o assets/tailwind.css --minify",
